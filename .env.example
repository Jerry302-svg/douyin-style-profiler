# LLM 配置由使用者自行填写；项目不提供任何 API key 或默认付费模型额度。
#
# 支持：
# - openai
# - deepseek
# - qwen
# - kimi / moonshot
# - zhipu
# - minimax
# - anthropic
# - gemini
# - openai-compatible（任意兼容 /v1/chat/completions 的平台或私有网关）

LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=

# 只有使用 openai-compatible、自建网关，或需要覆盖内置平台地址时才填写。
# 示例：https://api.example.com
LLM_BASE_URL=

LLM_TIMEOUT=180

# FunASR 转写模型。默认沿用楼大壮项目当前转写配置。
FUNASR_MODEL=paraformer-zh
FUNASR_MODEL_REVISION=v2.0.4
FUNASR_VAD_MODEL=fsmn-vad
FUNASR_PUNC_MODEL=ct-punc

# 模型默认下载到项目目录。
MODELSCOPE_CACHE=models/modelscope
